{
  "name": "intellibridge-server",
  "version": "1.0.0",
  "description": "IntelliBridge AI Backend Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "build": "npx tsc",
