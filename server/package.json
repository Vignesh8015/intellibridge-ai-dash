    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.8",
    "uuid": "^9.0.0",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^9.0.7",
    "prisma": "^5.22.0",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3"
  }
